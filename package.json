{
  "name": "ai-usage",
  "version": "1.0.0",
  "description": "Claude Code usage tray monitor",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/generate-icon.js",
    "dist": "npm run icon && electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Zsolt",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.claude.usage-monitor",
    "productName": "Claude Usage Monitor",
    "files": [
      "src/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-reloader": "^1.2.3"
  }
}
