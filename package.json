{
  "name": "krisvid-ai-usage-monitor",
  "version": "1.0.3",
  "description": "Krisvid — AI usage tray monitor",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "icon": "node scripts/generate-icon.js",
    "dist": "npm run icon && electron-builder",
    "dist:win": "npm run icon && electron-builder --win",
    "dist:mac": "npm run icon && electron-builder --mac",
    "dist:linux": "npm run icon && electron-builder --linux",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Zsolt Janes",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.janes.krisvid",
    "productName": "Krisvid",
    "files": [
      "src/**/*",
      "renderer/**/*",
      "resources/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "build/icons",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-reloader": "^1.2.3"
  }
}
